---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const allPosts = await Astro.glob('../../content/blog/*.md');
  
  return allPosts.map(post => {
    return {
      params: { slug: post.frontmatter.slug },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content } = post;
---

<Layout title={`${post.frontmatter.title} - Ola Store Blog`}>
  <article class="max-w-3xl mx-auto px-4 py-20">
    <nav class="text-sm text-gray-400 mb-6">
      <a href="/#blog" class="hover:text-ola-accent">← Kembali ke Blog</a>
    </nav>
    
    <header class="mb-8">
      <p class="text-ola-accent text-sm font-medium mb-2">
        {new Date(post.frontmatter.date).toLocaleDateString('id-ID', {
          year: 'numeric', month: 'long', day: 'numeric'
        })}
      </p>
      <h1 class="text-3xl md:text-4xl font-bold mb-4">{post.frontmatter.title}</h1>
      <p class="text-gray-400 text-lg">{post.frontmatter.description}</p>
    </header>
    
    <div class="border-t border-white/10 mb-8"></div>
    
    <div class="prose prose-invert prose-lg max-w-none">
      <Content />
    </div>
    
    <div class="border-t border-white/10 mt-12 pt-8">
      <a href="/#blog" class="text-ola-accent hover:underline">← Lihat artikel lainnya</a>
    </div>
  </article>
</Layout>
