---
import Layout from '../../layouts/Layout.astro';
import blogData from '../../data/blog.json';

export async function getStaticPaths() {
  return blogData.posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
---
<Layout title={post.title} description={post.excerpt}>
  <main style="max-width: 720px; margin: 0 auto; padding: 3rem 1.5rem;">
    <a href="/#blog">← Kembali ke Blog</a>
    <h1 style="margin-top: 1rem;">{post.title}</h1>
    <p style="color: #777;"><em>{new Date(post.date).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}</em></p>
    {post.image && <img src={post.image} alt={post.title} style="width:100%; border-radius: 8px; margin: 1.5rem 0;" />}
    {post.content.map((block) => {
  if (block.type === 'h2') return <h2 style="margin-top: 2rem; margin-bottom: 0.75rem;">{block.text}</h2>;
  if (block.type === 'h3') return <h3 style="margin-top: 1.5rem; margin-bottom: 0.5rem;">{block.text}</h3>;
  if (block.type === 'image') return <img src={block.src} alt={block.alt || post.title} style="width:100%; border-radius: 8px; margin: 1.5rem 0;" />;
  return <p style="line-height: 1.7; margin-bottom: 1rem;">{block.text}</p>;
})}
  </main>
</Layout>
