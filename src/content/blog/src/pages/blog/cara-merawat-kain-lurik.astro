---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Cara Merawat Kain Lurik - Ola Store Blog">
  <article class="max-w-3xl mx-auto px-4 py-20">
    <nav class="text-sm text-gray-400 mb-6">
      <a href="/#blog" class="hover:text-ola-accent">← Kembali ke Blog</a>
    </nav>
    
    <header class="mb-8">
      <p class="text-ola-accent text-sm font-medium mb-2">19 Juli 2025</p>
      <h1 class="text-3xl md:text-4xl font-bold mb-4">Cara Merawat Kain Lurik</h1>
      <p class="text-gray-400 text-lg">Tips merawat kain lurik agar awet dan tetap indah</p>
    </header>
    
    <div class="border-t border-white/10 mb-8"></div>
    
    <div class="prose prose-invert prose-lg max-w-none">
      <p>Isi artikel tentang cara merawat kain lurik...</p>
    </div>
    
    <div class="border-t border-white/10 mt-12 pt-8">
      <a href="/#blog" class="text-ola-accent hover:underline">← Lihat artikel lainnya</a>
    </div>
  </article>
</Layout>

