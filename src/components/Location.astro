---
import site from '../data/site.json';
---

<section class="location" id="lokasi">
  <h2>Kunjungi Kami</h2>
  <p class="location-sub">Datang langsung ke toko kami di Pasar Klewer Solo</p>
  <div class="map-placeholder">
    <iframe 
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3955.1!2d110.826!3d-7.566!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e7a1660!2sPasar+Klewer!5e0!3m2!1sid!2sid!4v1234567890" 
      width="100%" 
      height="100%" 
      style="border:0;" 
      allowfullscreen="" 
      loading="lazy" 
      referrerpolicy="strict-origin-when-cross-origin">
    </iframe>
  </div>
  <div class="location-details">
    <span>📍</span>
    <div>
      <strong>{site.location}</strong>
      <small>{site.city}</small>
    </div>
  </div>
</section>
