---
const posts = await Astro.glob('../content/blog/*.md');
posts.sort((a, b) => new Date(b.frontmatter.date) - new Date(a.frontmatter.date));
---

<section id="blog" class="py-20 px-4">
  <div class="max-w-4xl mx-auto">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-3xl font-bold">Blog Ola Store</h2>
      <span class="text-sm text-gray-400">{posts.length} artikel</span>
    </div>
    
    {posts.length === 0 ? (
      <div class="text-center py-12 text-gray-500">
        <p>Belum ada artikel.</p>
      </div>
    ) : (
      <div class="grid gap-6">
        {posts.map(post => (
          <article class="bg-white/5 rounded-xl p-6 border border-white/10 hover:border-ola-accent/50 transition group">
            <a href={`/blog/${post.frontmatter.slug}/`}>


              <div class="flex items-start justify-between gap-4">
                <div class="flex-1">
                  <p class="text-xs text-ola-accent font-medium mb-2">
                    {new Date(post.frontmatter.date).toLocaleDateString('id-ID', {
                      year: 'numeric', month: 'long', day: 'numeric'
                    })}
                  </p>
                  <h3 class="text-xl font-semibold mb-2 group-hover:text-ola-accent transition">
                    {post.frontmatter.title}
                  </h3>
                  <p class="text-gray-400 text-sm line-clamp-2">
                    {post.frontmatter.description}
                  </p>
                  <span class="inline-block mt-3 text-sm text-ola-accent opacity-0 group-hover:opacity-100 transition">
                    Baca selengkapnya →
                  </span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    )}
  </div>
</section>
