---
import site from '../data/site.json';
---

<section class="hero" id="home">
  <div class="hero-inner">
    <div class="hero-content">
      <div class="hero-badge">
        <span>🏛️</span> {site.location}
      </div>
      <h1>Lurik & Busana Jawa<br><span>Asli Kota Solo</span></h1>
      <p>Koleksi lurik tradisional dan busana Jawa "Surjane Ola", berkualitas dari pengrajin lokal Kota Solo. Sentuhan warisan, gaya masa kini.</p>
      <div class="hero-buttons">
        <a href="#produk" class="btn-primary">Lihat Katalog →</a>
        <a href={`https://wa.me/${site.waNumber}`} class="btn-secondary" target="_blank">💬 Chat WA</a>
      </div>
    </div>
    <div class="hero-image">
      <div class="hero-img-frame">
        <!-- GANTI FOTO: taruh gambar di public/images/hero.webp -->
        <img src="/images/hero.webp" alt="Koleksi Lurik Ola Store" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
        <div class="hero-img-placeholder" style="display:none;">
          <span class="icon">👘</span>
          <span>Taruh foto di<br>public/images/hero.webp</span>
        </div>
      </div>
      <div class="floating-tag tag-1">⭐ {site.rating} Rating</div>
      <div class="floating-tag tag-2">✅ {site.reviews} Ulasan</div>
    </div>
  </div>
</section>
